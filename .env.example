# PostgreSQL (docker-compose db service)
POSTGRES_DB=homecloud
POSTGRES_USER=homecloud
POSTGRES_PASSWORD=changeme

# Application database
DATABASE_URL=postgresql+asyncpg://homecloud:changeme@db:5432/homecloud

# First administrator (created by init_db.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379

# Storage
STORAGE_DISKS=disk1
STORAGE_ROOT=/storage
DISK_STRATEGY=most_free_space
DISK_SPACE_CACHE_TTL=30
MIN_FREE_SPACE_MB=500

# Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://filenkov.store:8000/api/auth/google/callback
FRONTEND_URL=http://filenkov.store
JWT_SECRET=change-me-to-a-random-secret
SESSION_TTL_SECONDS=86400
PRIVATE_SESSION_TTL_HOURS=4

# Business logic
PHOTO_BATCH_SIZE=30
THUMBNAIL_MAX_PX=400
STRANGER_QUOTA_MB=100
ARCHIVE_DAYS_THRESHOLD=180

# Logging (structured JSON via python-json-logger)
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false
LOG_FILE_PATH=/var/log/homecloud/app.log
LOG_FILE_ROTATION=100 MB
LOG_FILE_RETENTION=30 days

# Frontend (local dev only, not used by backend container)
# VITE_API_BASE_URL=http://localhost:8000
# API_PROXY_TARGET=http://localhost:8000
