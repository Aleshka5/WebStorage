# PostgreSQL (docker-compose db service)
POSTGRES_DB=homecloud
POSTGRES_USER=homecloud
POSTGRES_PASSWORD=changeme

# Application
DATABASE_URL=postgresql+asyncpg://homecloud:changeme@db:5432/homecloud
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
REDIS_URL=redis://redis:6379
STORAGE_DISKS=disk1
STORAGE_ROOT=/storage
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me-to-a-random-secret
SESSION_TTL_SECONDS=86400
PRIVATE_SESSION_TTL_HOURS=4
PHOTO_BATCH_SIZE=30
THUMBNAIL_MAX_PX=400
STRANGER_QUOTA_MB=100
ARCHIVE_DAYS_THRESHOLD=180
DISK_STRATEGY=most_free_space
DISK_SPACE_CACHE_TTL=30
MIN_FREE_SPACE_MB=500
